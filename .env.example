# Flask application configuration
SECRET_KEY=your_secret_key_here

# Database configuration (Heroku provides DATABASE_URL automatically)
DATABASE_URL=postgresql://...
# Fallback for local development
DATABASE_URI=sqlite:///scrounge.db

# Fernet encryption key for data at rest (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=your_fernet_key_here

# Set to 'true' only for local development
FLASK_DEBUG=false